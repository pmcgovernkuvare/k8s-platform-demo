{
  "title": "Platform / GitOps & Mesh Health",
  "uid": "gitops-platform-health",
  "tags": ["platform-demo", "argocd", "linkerd", "kong"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "ArgoCD Application Sync Status",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "argocd_app_info", "format": "table", "instant": true }
      ]
    },
    {
      "id": 2,
      "title": "ArgoCD Sync Health by Environment",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(argocd_app_info{health_status=\"Healthy\"}) by (dest_namespace)", "legendFormat": "healthy - {{dest_namespace}}" },
        { "expr": "sum(argocd_app_info{health_status!=\"Healthy\"}) by (dest_namespace)", "legendFormat": "unhealthy - {{dest_namespace}}" }
      ]
    },
    {
      "id": 3,
      "title": "Kong Gateway Request Rate by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(kong_http_requests_total[5m])) by (route)", "legendFormat": "{{route}}" }
      ]
    },
    {
      "id": 4,
      "title": "Linkerd mTLS Coverage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(response_total{tls=\"true\"}[5m])) / sum(rate(response_total[5m]))" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0, "thresholds": { "steps": [ {"color": "red", "value": null}, {"color": "yellow", "value": 0.8}, {"color": "green", "value": 0.99} ] } }, "overrides": [] }
    },
    {
      "id": 5,
      "title": "Pod Restarts (last hour, dev/test/prod)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"dev|test|prod\"}[1h])) by (namespace, pod)", "legendFormat": "{{namespace}}/{{pod}}" }
      ]
    }
  ]
}
